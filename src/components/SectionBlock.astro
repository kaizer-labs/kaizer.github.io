---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
  id?: string;
}

const { eyebrow, title, description, id } = Astro.props;
---

<section class="section-block" id={id}>
  <div class="section-block__header">
    <p class="section-kicker">{eyebrow}</p>
    <h2>{title}</h2>
    {description ? <p class="section-copy">{description}</p> : null}
  </div>
  <div class="section-block__content">
    <slot />
  </div>
</section>
