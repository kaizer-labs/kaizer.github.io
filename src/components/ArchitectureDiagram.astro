---
interface Props {
  title: string;
  summary: string;
  layers: Array<{
    name: string;
    description: string;
    bullets: string[];
  }>;
}

const { title, summary, layers } = Astro.props;
---

<section class="architecture-panel" aria-labelledby="architecture-title">
  <div class="architecture-panel__header">
    <p class="section-kicker">Architecture</p>
    <h2 id="architecture-title">{title}</h2>
    <p>{summary}</p>
  </div>

  <div class="architecture-diagram" aria-label={title}>
    {layers.map((layer, index) => (
      <article class="architecture-layer">
        <div class="architecture-layer__rail" aria-hidden="true">
          <span class="architecture-layer__dot"></span>
          {index < layers.length - 1 && <span class="architecture-layer__line"></span>}
        </div>
        <div class="architecture-layer__card">
          <p class="architecture-layer__index">Layer 0{index + 1}</p>
          <h3>{layer.name}</h3>
          <p>{layer.description}</p>
          <ul>
            {layer.bullets.map((bullet) => <li>{bullet}</li>)}
          </ul>
        </div>
      </article>
    ))}
  </div>
</section>
