---
interface Milestone {
  date: string;
  roleTitle?: string;
  label: string;
  detail: string;
}

interface Item {
  id: string;
  company: string;
  role: string;
  period: string;
  startDate: string;
  endDate: string;
  milestones: Milestone[];
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;
const sortedItems = [...items].sort((a, b) => a.startDate.localeCompare(b.startDate));
const currentPrimaryItem =
  sortedItems.find((item) => item.company === "Goodyear") ??
  sortedItems.find((item) => item.period.includes("Present")) ??
  sortedItems[0];
const currentPrimaryMilestone = currentPrimaryItem?.milestones[currentPrimaryItem.milestones.length - 1];
const formatMonthYear = (value?: string) =>
  value
    ? new Intl.DateTimeFormat("en-US", { month: "long", year: "numeric" }).format(
        new Date(`${value}-01T00:00:00`)
      )
    : "";
---

<div class="professional-timeline-d3" data-timeline-root data-items={JSON.stringify(sortedItems)}>
  <div class="professional-timeline-d3__stage">
    <div class="professional-timeline-d3__legend">
      {sortedItems.map((item) => (
        <div class="professional-timeline-d3__legend-item">
          <span class:list={["professional-timeline-d3__legend-dot", `is-${item.id}`]}></span>
          <span>{item.company}</span>
        </div>
      ))}
    </div>
    <p class="professional-timeline-d3__hint">Drag the handle or hover the line to explore milestones.</p>
    <svg class="professional-timeline-d3__svg" data-timeline-svg aria-label="Professional work timeline"></svg>
  </div>
  <aside class="professional-timeline-d3__details" data-timeline-details>
    <p class="section-kicker">Professional work</p>
    <div class="professional-timeline-d3__current">
      <p class="professional-timeline-d3__current-label">Current primary role</p>
      <p class="professional-timeline-d3__current-role">
        {currentPrimaryItem?.role} · {currentPrimaryItem?.company}
      </p>
      <p class="professional-timeline-d3__current-note">
        Leading this role today while continuing independent AI and market-analysis exploration outside work.
      </p>
    </div>
    <h3 data-detail-role>{currentPrimaryItem?.role}</h3>
    <p class="professional-timeline-d3__company" data-detail-company>{currentPrimaryItem?.company}</p>
    <p class="professional-timeline-d3__period" data-detail-period>{currentPrimaryItem?.period}</p>
    <div class="professional-timeline-d3__milestone">
      <p class="professional-timeline-d3__milestone-date" data-detail-date>
        {formatMonthYear(currentPrimaryMilestone?.date)}
      </p>
      <h4 data-detail-label>{currentPrimaryMilestone?.label}</h4>
      <p data-detail-text>{currentPrimaryMilestone?.detail}</p>
    </div>
  </aside>
</div>

<script type="module">
  import * as d3 from "https://cdn.jsdelivr.net/npm/d3@7/+esm";

  const roots = document.querySelectorAll("[data-timeline-root]");

  for (const root of roots) {
    const raw = root.getAttribute("data-items");
    if (!raw) continue;

    const items = JSON.parse(raw);
    const svg = root.querySelector("[data-timeline-svg]");
    const details = root.querySelector("[data-timeline-details]");
    if (!svg || !details) continue;

    const roleEl = details.querySelector("[data-detail-role]");
    const companyEl = details.querySelector("[data-detail-company]");
    const periodEl = details.querySelector("[data-detail-period]");
    const dateEl = details.querySelector("[data-detail-date]");
    const labelEl = details.querySelector("[data-detail-label]");
    const textEl = details.querySelector("[data-detail-text]");

    const milestones = items.flatMap((item) =>
      item.milestones.map((milestone) => ({
        ...milestone,
        item,
        parsedDate: new Date(`${milestone.date}-01T00:00:00`)
      }))
    ).sort((a, b) => a.parsedDate - b.parsedDate);

    const stage = root.querySelector(".professional-timeline-d3__stage");
    const width = stage?.clientWidth || 960;
    const isMobile = window.matchMedia("(max-width: 959px)").matches;
    const margin = isMobile
      ? { top: 36, right: 22, bottom: 34, left: 22 }
      : { top: 44, right: 36, bottom: 46, left: 36 };
    const innerWidth = Math.max(320, width - margin.left - margin.right);
    const height = isMobile ? 270 : 320;

    const itemIds = items.map((item) => item.id);
    const color = d3.scaleOrdinal()
      .domain(itemIds)
      .range(["#0f766e", "#1d4ed8", "#d97706"]);

    const x = d3.scaleTime()
      .domain(d3.extent(milestones, (d) => d.parsedDate))
      .range([margin.left, margin.left + innerWidth]);

    const axisY = height - margin.bottom;
    const lineY = axisY - (isMobile ? 86 : 112);
    const endReference = d3.timeMonth.offset(d3.max(milestones, (d) => d.parsedDate), 2);

    const rootSvg = d3.select(svg)
      .attr("viewBox", `0 0 ${width} ${height}`)
      .attr("preserveAspectRatio", "xMidYMid meet");

    rootSvg.selectAll("*").remove();

    rootSvg.append("line")
      .attr("class", "professional-timeline-d3__axis-line")
      .attr("x1", margin.left)
      .attr("x2", margin.left + innerWidth)
      .attr("y1", axisY)
      .attr("y2", axisY);

    const axis = d3.axisBottom(x)
      .ticks(isMobile ? 4 : 6)
      .tickFormat(d3.timeFormat("%b %Y"));

    rootSvg.append("g")
      .attr("class", "professional-timeline-d3__axis")
      .attr("transform", `translate(0, ${axisY})`)
      .call(axis)
      .call((g) => g.select(".domain").remove());

    const backdrop = rootSvg.append("g").attr("class", "professional-timeline-d3__backdrop");

    backdrop.selectAll("rect")
      .data(items)
      .enter()
      .append("rect")
      .attr("class", "professional-timeline-d3__band")
      .attr("x", (d) => x(new Date(`${d.startDate}-01T00:00:00`)))
      .attr("y", lineY + 28 + (isMobile ? 0 : 2))
      .attr("width", (d) => {
        const endDate =
          d.endDate === "Present"
            ? endReference
            : new Date(`${d.endDate}-01T00:00:00`);
        return Math.max(24, x(endDate) - x(new Date(`${d.startDate}-01T00:00:00`)));
      })
      .attr("height", isMobile ? 10 : 12)
      .attr("rx", 999)
      .attr("fill", (d) => d3.color(color(d.id)).copy({ opacity: 0.16 }));

    backdrop.append("path")
      .attr("class", "professional-timeline-d3__elastic-line")
      .attr(
        "d",
        d3.line()
          .x((d) => x(d.parsedDate))
          .y(() => lineY)
          .curve(d3.curveCatmullRom.alpha(0.65))(milestones)
      );

    backdrop.selectAll("line")
      .data(items)
      .enter()
      .append("line")
      .attr("class", "professional-timeline-d3__guide")
      .attr("x1", margin.left)
      .attr("x2", margin.left + innerWidth)
      .attr("y1", lineY)
      .attr("y2", lineY)
      .attr("stroke", (d) => d3.color(color(d.id)).copy({ opacity: 0.15 }));

    const milestoneGroup = rootSvg.append("g").attr("class", "professional-timeline-d3__milestones");
    const tooltipGroup = rootSvg.append("g")
      .attr("class", "professional-timeline-d3__tooltip")
      .style("pointer-events", "none");
    const travelerGroup = rootSvg.append("g")
      .attr("class", "professional-timeline-d3__traveler")
      .style("pointer-events", "none");

    const tooltipRect = tooltipGroup.append("rect")
      .attr("rx", 14)
      .attr("ry", 14)
      .attr("class", "professional-timeline-d3__tooltip-box");

    const tooltipDate = tooltipGroup.append("text")
      .attr("class", "professional-timeline-d3__tooltip-date");

    const tooltipTitle = tooltipGroup.append("text")
      .attr("class", "professional-timeline-d3__tooltip-title");

    travelerGroup.append("rect")
      .attr("class", "professional-timeline-d3__traveler-body")
      .attr("x", -16)
      .attr("y", -9)
      .attr("width", 28)
      .attr("height", 10)
      .attr("rx", 5);

    travelerGroup.append("rect")
      .attr("class", "professional-timeline-d3__traveler-sidepod")
      .attr("x", -10)
      .attr("y", -4)
      .attr("width", 14)
      .attr("height", 6)
      .attr("rx", 3);

    travelerGroup.append("rect")
      .attr("class", "professional-timeline-d3__traveler-cockpit")
      .attr("x", -2)
      .attr("y", -14)
      .attr("width", 10)
      .attr("height", 8)
      .attr("rx", 3);

    travelerGroup.append("circle")
      .attr("class", "professional-timeline-d3__traveler-wheel")
      .attr("cx", -8)
      .attr("cy", 3)
      .attr("r", 4);

    travelerGroup.append("circle")
      .attr("class", "professional-timeline-d3__traveler-wheel")
      .attr("cx", 8)
      .attr("cy", 3)
      .attr("r", 4);

    travelerGroup.append("path")
      .attr("class", "professional-timeline-d3__traveler-wing")
      .attr("d", "M 12 -7 L 18 -5 L 18 -1 L 12 1 Z");

    travelerGroup.append("path")
      .attr("class", "professional-timeline-d3__traveler-streak")
      .attr("d", "M -34 -7 L -20 -5 M -32 -2 L -18 -1 M -30 3 L -16 4");

    travelerGroup.append("circle")
      .attr("class", "professional-timeline-d3__traveler-trail trail-one")
      .attr("cx", -22)
      .attr("cy", -3)
      .attr("r", 2.5);

    travelerGroup.append("circle")
      .attr("class", "professional-timeline-d3__traveler-trail trail-two")
      .attr("cx", -28)
      .attr("cy", -1)
      .attr("r", 2);

    travelerGroup.append("circle")
      .attr("class", "professional-timeline-d3__traveler-trail trail-three")
      .attr("cx", -33)
      .attr("cy", 1)
      .attr("r", 1.75);

    const updateDetails = (datum) => {
      if (!datum) return;
      roleEl.textContent = datum.roleTitle || datum.item.role;
      companyEl.textContent = datum.item.company;
      periodEl.textContent = datum.item.period;
      dateEl.textContent = d3.timeFormat("%B %Y")(datum.parsedDate);
      labelEl.textContent = datum.label;
      textEl.textContent = datum.detail;
    };

    const setActive = (datum) => {
      milestoneGroup.selectAll(".professional-timeline-d3__event")
        .classed("is-active", (d) => d === datum);
      const xPos = x(datum.parsedDate);
      const yPos = lineY;
      const tooltipWidth = isMobile ? 220 : 320;
      const tooltipHeight = isMobile ? 52 : 60;
      const tooltipX = Math.max(
        margin.left,
        Math.min(margin.left + innerWidth - tooltipWidth, xPos - tooltipWidth / 2)
      );
      const tooltipY = yPos - (isMobile ? 66 : 82);

      tooltipGroup.attr("transform", `translate(${tooltipX}, ${tooltipY})`);
      tooltipRect
        .attr("width", tooltipWidth)
        .attr("height", tooltipHeight);
      tooltipDate
        .attr("x", 14)
        .attr("y", isMobile ? 18 : 20)
        .text(d3.timeFormat("%b %Y")(datum.parsedDate));
      tooltipTitle
        .attr("x", 14)
        .attr("y", isMobile ? 38 : 40)
        .text(datum.label);
      updateDetails(datum);
    };

    const events = milestoneGroup.selectAll("g")
      .data(milestones)
      .enter()
      .append("g")
      .attr("class", "professional-timeline-d3__event")
      .attr("transform", (d) => `translate(${x(d.parsedDate)}, ${lineY})`)
      .style("cursor", "pointer")
      .on("mouseenter", (_, d) => setActive(d))
      .on("click", (_, d) => setActive(d));

    events.append("circle")
      .attr("class", "professional-timeline-d3__event-ring")
      .attr("r", isMobile ? 10 : 12)
      .attr("fill", (d) => d3.color(color(d.item.id)).copy({ opacity: 0.16 }))
      .attr("stroke", "none");

    events.append("circle")
      .attr("class", "professional-timeline-d3__event-dot")
      .attr("r", isMobile ? 4.5 : 5.5)
      .attr("fill", (d) => color(d.item.id));

    events.append("text")
      .attr("class", "professional-timeline-d3__event-label")
      .attr("text-anchor", "middle")
      .attr("dy", isMobile ? 24 : 28)
      .text((d) => (d.item.company === "Goodyear" && d.label.includes("Continuing") ? "Current role" : ""));

    const scrubberGroup = rootSvg.append("g").attr("class", "professional-timeline-d3__scrubber");
    const initialActive =
      milestones.find((milestone) => milestone.item.company === "Goodyear" && milestone.label.includes("Continuing")) ??
      milestones.find((milestone) => milestone.item.company === "Goodyear") ??
      milestones[milestones.length - 1] ??
      milestones[0];

    scrubberGroup.append("line")
      .attr("class", "professional-timeline-d3__scrubber-line")
      .attr("y1", margin.top + 10)
      .attr("y2", axisY - 10);

    scrubberGroup.append("circle")
      .attr("class", "professional-timeline-d3__scrubber-handle")
      .attr("r", isMobile ? 10 : 12)
      .attr("cy", axisY);

    const moveScrubber = (datum) => {
      const xPos = x(datum.parsedDate);
      scrubberGroup.attr("transform", `translate(${xPos}, 0)`);
      travelerGroup
        .attr("transform", `translate(${xPos}, ${lineY - 18})`)
        .attr("data-company", datum.item.id);
      setActive(datum);
    };

    const nearestMilestone = (xPos) => {
      let best = milestones[0];
      let bestDistance = Infinity;
      for (const milestone of milestones) {
        const distance = Math.abs(x(milestone.parsedDate) - xPos);
        if (distance < bestDistance) {
          best = milestone;
          bestDistance = distance;
        }
      }
      return best;
    };

    const dragBehavior = d3.drag()
      .on("drag", (event) => {
        const clampedX = Math.max(margin.left, Math.min(margin.left + innerWidth, event.x));
        moveScrubber(nearestMilestone(clampedX));
      });

    scrubberGroup.call(dragBehavior);
    rootSvg.on("mousemove", (event) => {
      const [mouseX] = d3.pointer(event);
      moveScrubber(nearestMilestone(mouseX));
    });
    rootSvg.on("mouseleave", () => {
      moveScrubber(initialActive);
    });

    if (milestones.length > 0) {
      moveScrubber(initialActive);
    }
  }
</script>
