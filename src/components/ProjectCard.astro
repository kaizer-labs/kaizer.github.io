---
import TechTag from "./TechTag.astro";

interface Props {
  project: {
    id: string;
    data: {
      title: string;
      summary: string;
      status: string;
      tech: string[];
    };
  };
}

const { project } = Astro.props;
---

<a class="project-card" href={`/projects/${project.id}/`} transition:name={`project-${project.id}`}>
  <div class="project-card__top">
    <span class="project-card__status">{project.data.status}</span>
    <h3>{project.data.title}</h3>
  </div>
  <p>{project.data.summary}</p>
  <div class="project-card__tags">
    {project.data.tech.slice(0, 4).map((tag) => <TechTag label={tag} />)}
  </div>
</a>
