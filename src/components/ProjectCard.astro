---
import TechTag from "./TechTag.astro";

interface Props {
  project: {
    id: string;
    data: {
      title: string;
      subtitle: string;
      summary: string;
      problem: string;
      status: string;
      year: string;
      metrics: string[];
      tech: string[];
    };
  };
}

const { project } = Astro.props;
---

<a class="project-card" href={`/projects/${project.id}/`}>
  <div class="project-card__eyebrow">
    <span class="project-card__status">{project.data.status}</span>
  </div>
  <div class="project-card__top">
    <h3>{project.data.title}</h3>
    <p class="project-card__subtitle">{project.data.subtitle}</p>
  </div>
  <p class="project-card__problem">{project.data.problem}</p>
  <p>{project.data.summary}</p>
  <div class="project-card__metrics">
    {project.data.metrics.slice(0, 3).map((metric) => <span>{metric}</span>)}
  </div>
  <div class="project-card__tags">
    {project.data.tech.slice(0, 4).map((tag) => <TechTag label={tag} />)}
  </div>
</a>
