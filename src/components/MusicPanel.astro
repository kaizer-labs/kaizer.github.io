---
interface QueueItem {
  title: string;
  meta: string;
  note: string;
}

interface Props {
  items: QueueItem[];
}

const { items } = Astro.props;
---

<div class="music-panel">
  <div class="music-panel__header">
    <p class="section-kicker">Current queue</p>
    <p class="music-panel__caption">Playlist-inspired module, built from real focus areas instead of invented track data.</p>
  </div>

  <div class="music-panel__list">
    {items.map((item, index) => (
      <article class="music-panel__row">
        <span class="music-panel__index">{String(index + 1).padStart(2, "0")}</span>
        <div>
          <h3>{item.title}</h3>
          <p>{item.note}</p>
        </div>
        <span class="music-panel__meta">{item.meta}</span>
      </article>
    ))}
  </div>
</div>
