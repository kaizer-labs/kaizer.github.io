---
import { getCollection } from "astro:content";
import MainLayout from "../layouts/MainLayout.astro";
import SectionBlock from "../components/SectionBlock.astro";
import ProjectCard from "../components/ProjectCard.astro";
import ProfessionalTimeline from "../components/ProfessionalTimeline.astro";
import { leadershipSignals, proofPoints, site, workTimeline } from "../data/site";

const projects = (await getCollection("projects")).sort((a, b) => a.data.order - b.data.order);
const featured = projects.filter((project) => project.data.featured).slice(0, 3);
---

<MainLayout
  title="Kaizer Charania | Staff Engineer and Engineering Manager Profile"
  description="Portfolio for Kaizer Charania, a technical leader spanning staff engineer and engineering manager scope across backend, platform, and distributed systems."
  frameClass="site-frame--home"
>
  <section class="hero">
    <div class="hero__surface">
      <div class="hero__content">
        <div class="hero__content-inner">
          <p class="section-kicker">Staff Engineer • Engineering Manager • Backend • Platform</p>
          <h1 class="hero__headline-plain">{site.heroHeadline}</h1>
          <p class="hero__lede">{site.heroIntro}</p>
          <div class="tag-row">
            {proofPoints.slice(0, 3).map((item) => <span class="tech-tag">{item.value}</span>)}
          </div>
          <div class="hero__actions">
            <a class="button" href="/projects/">See case studies</a>
            <a class="button button--ghost" href={site.resume} target="_blank" rel="noreferrer">View resume</a>
          </div>
        </div>
      </div>

      <div class="hero__visual" aria-hidden="true">
        <div class="hero__visual-glow hero__visual-glow--one"></div>
        <div class="hero__visual-glow hero__visual-glow--two"></div>
        <div class="hero__visual-grid"></div>
        <div class="hero__stars">
          <span class="hero__star hero__star--1"></span>
          <span class="hero__star hero__star--2"></span>
          <span class="hero__star hero__star--3"></span>
          <span class="hero__star hero__star--4"></span>
          <span class="hero__star hero__star--5"></span>
          <span class="hero__star hero__star--6"></span>
        </div>
        <div class="hero__signal-card">
          <p class="section-kicker">At a glance</p>
          <p class="hero__signal-copy">{site.contactBody}</p>
          <div class="hero__stack">
            <span class="tech-tag">7+ years</span>
            <span class="tech-tag">8-engineer team scope</span>
            <span class="tech-tag">Architecture + execution</span>
          </div>
        </div>
        <div class="hero__signal-path">
          <span></span>
          <span></span>
          <span></span>
        </div>
      </div>
    </div>
  </section>

  <SectionBlock
    eyebrow="Professional work"
    title="The main chapters of my professional work so far."
    description="Most of my career has been shaped by backend, platform, and systems work that sits close to operations, data, and the engineering process itself."
    className="section-block--wide-title"
  >
    <ProfessionalTimeline items={workTimeline} />
  </SectionBlock>

  <SectionBlock
    eyebrow="Featured work"
    title="Case studies where technical depth and leadership show up together."
    description="These projects are the clearest examples of architecture, performance, delivery discipline, and business impact reinforcing each other."
    className="section-block--wide-title"
  >
    <div class="project-grid">
      {featured.map((project) => <ProjectCard project={project} />)}
    </div>
  </SectionBlock>

  <SectionBlock
    eyebrow="Leadership"
    title="How I tend to lead when the work gets complex."
    description={site.radarBody}
    className="section-block--wide-title"
  >
    <div class="leadership-spotlight">
      <article class="leadership-spotlight__intro">
        <p class="section-kicker">Leadership snapshot</p>
        <p>{site.recruiterIntro}</p>
      </article>
      <div class="leadership-spotlight__grid">
        {leadershipSignals.map((item, index) => (
          <article class:list={["leadership-spotlight__card", index === 0 && "is-featured"]}>
            <p class="leadership-spotlight__index">0{index + 1}</p>
          <p>{item}</p>
          </article>
        ))}
      </div>
    </div>
  </SectionBlock>

  <section class="final-cta">
    <p class="section-kicker">Connect</p>
    <h2>{site.contactHeadline}</h2>
    <p>{site.contactBody}</p>
    <div class="hero__actions">
      <a class="button" href="/contact/">Connect</a>
      <a class="button button--ghost" href="/about/">About me</a>
    </div>
  </section>
</MainLayout>
