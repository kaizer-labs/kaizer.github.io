---
import MainLayout from "../layouts/MainLayout.astro";
import SectionBlock from "../components/SectionBlock.astro";
import { leadershipSignals, site, skills, story, timeline, values } from "../data/site";
---

<MainLayout
  title="About | Kaizer Charania"
  description="About page for Kaizer Charania covering technical leadership across staff engineer and engineering manager scope."
  frameClass="site-frame--about"
>
  <SectionBlock
    eyebrow="About"
    title="I build systems that scale, and I care about helping teams scale with them."
    description="I operate across architecture, modernization, performance, mentoring, and execution discipline, with the goal of making both the system and the team more effective over time."
  >
    <div class="content-stack">
      {story.map((paragraph) => <p>{paragraph}</p>)}
    </div>
  </SectionBlock>

  <SectionBlock
    eyebrow="Operating style"
    title="How I think about systems, teams, and technical decisions."
    description="The pattern I keep coming back to is durable decision-making: solve the immediate problem, reduce future drag, and leave the team in a better operating position."
    className="section-block--wide-title"
  >
    <div class="about-operating">
      <article class="about-operating__lead">
        <p class="section-kicker">Operating principles</p>
        <p>
          I try to make technical leadership feel concrete. That usually means solving the immediate
          system problem, but also improving the decision quality, team rhythm, and engineering
          habits around it so the same friction does not keep coming back.
        </p>
      </article>
      <div class="about-operating__grid">
        {values.map((item, index) => (
          <article class:list={["about-operating__card", index === 0 && "is-featured"]}>
            <p class="about-operating__index">0{index + 1}</p>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </div>
  </SectionBlock>

  <SectionBlock
    eyebrow="Career arc"
    title="How the scope of my work has expanded over time."
  >
    <div class="about-arc">
      {timeline.map((item, index) => (
        <article class="about-arc__item">
          <div class="about-arc__rail">
            <span class="about-arc__dot"></span>
            {index < timeline.length - 1 ? <span class="about-arc__line"></span> : null}
          </div>
          <div class="about-arc__content">
            <p class="about-arc__step">Step 0{index + 1}</p>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </div>
        </article>
      ))}
    </div>
  </SectionBlock>

  <SectionBlock
    eyebrow="Team leadership"
    title="Where the work moves beyond individual technical contribution."
    description="A meaningful part of my work has been creating better review quality, clearer standards, stronger onboarding, and more reliable delivery habits across a team."
  >
    <div class="leadership-spotlight">
      <article class="leadership-spotlight__intro">
        <p class="section-kicker">Leadership snapshot</p>
        <p>
          I care about leadership most when it becomes tangible in the team’s day-to-day experience:
          clearer decisions, better review quality, stronger onboarding, and execution habits that
          reduce friction instead of adding more process.
        </p>
      </article>
      <div class="leadership-spotlight__grid">
        {leadershipSignals.map((item, index) => (
          <article class:list={["leadership-spotlight__card", index === 0 && "is-featured"]}>
            <p class="leadership-spotlight__index">0{index + 1}</p>
            <p>{item}</p>
          </article>
        ))}
      </div>
    </div>
  </SectionBlock>

  <SectionBlock
    eyebrow="Strengths"
    title="The technical foundations I keep coming back to."
    description="The core of my work remains backend systems, platform design, architecture-led execution, and the ability to stay close to technical detail while operating at broader scope."
  >
    <div class="about-strengths">
      <article class="about-strengths__hero">
        <p class="section-kicker">Where I add the most leverage</p>
        <h3>Backend depth, platform judgment, and execution systems that make teams easier to scale.</h3>
        <p>
          The throughline in my work is not just shipping backend systems. It is making those systems
          faster, more durable, and easier for a team to build on without slowing delivery down.
        </p>
      </article>
      <article class="skill-group about-strengths__card">
        <h3>Backend systems</h3>
        <div class="tag-row">
          {skills.backend.map((item) => <span class="tech-tag">{item}</span>)}
        </div>
      </article>
      <article class="skill-group about-strengths__card">
        <h3>Platform and execution</h3>
        <div class="tag-row">
          {skills.methodology.map((item) => <span class="tech-tag">{item}</span>)}
        </div>
      </article>
      <article class="skill-group about-strengths__card">
        <h3>Supporting full-stack range</h3>
        <div class="tag-row">
          {skills.frontend.map((item) => <span class="tech-tag">{item}</span>)}
        </div>
      </article>
    </div>
  </SectionBlock>

  <section class="final-cta">
    <p class="section-kicker">Next step</p>
    <h2>See the case studies behind the technical-leadership narrative.</h2>
    <div class="hero__actions">
      <a class="button" href="/projects/">Explore projects</a>
      <a class="button button--ghost" href="/contact/">Connect</a>
    </div>
  </section>
</MainLayout>
