---
import { getCollection, render } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import TechTag from "../../components/TechTag.astro";
import ArchitectureDiagram from "../../components/ArchitectureDiagram.astro";

export async function getStaticPaths() {
  const projects = (await getCollection("projects")).sort((a, b) => a.data.order - b.data.order);

  return projects.map((project, index) => ({
    params: { slug: project.id },
    props: {
      project,
      previous: projects[index - 1] ?? null,
      next: projects[index + 1] ?? null
    }
  }));
}

const { project, previous, next } = Astro.props;
const { Content } = await render(project);
---

<MainLayout
  title={`${project.data.title} | Kaizer Charania`}
  description={project.data.summary}
  frameClass="site-frame--home"
>
  <article class="project-detail">
    <a class="back-link" href="/projects/">← Back to projects</a>

    <header class="project-detail__hero">
      <div class="project-detail__hero-copy">
        <div class="project-detail__meta">
          <span>{project.data.year}</span>
          <span>{project.data.status}</span>
          <span>{project.data.role}</span>
        </div>
        <p class="section-kicker">Case study</p>
        <h1>{project.data.title}</h1>
        <p class="project-detail__subtitle">{project.data.subtitle}</p>
        <p>{project.data.summary}</p>
        <div class="tag-row">
          {project.data.tech.map((tag) => <TechTag label={tag} />)}
        </div>
      </div>

      <aside class="project-detail__hero-brief">
        <div class="project-brief">
          <p class="project-brief__label">Problem</p>
          <p>{project.data.problem}</p>
        </div>
        <div class="project-brief">
          <p class="project-brief__label">Scope</p>
          <p>{project.data.scope}</p>
        </div>
      </aside>
    </header>

    <section class="detail-panel detail-panel--metrics">
      <div class="detail-panel__header">
        <p class="section-kicker">Impact</p>
        <h2>Key production outcomes</h2>
      </div>
      <div class="project-metric-strip">
        {project.data.metrics.map((metric) => <div class="project-metric-strip__item">{metric}</div>)}
      </div>
    </section>

    <section class="detail-panel">
      <div class="detail-panel__header">
        <p class="section-kicker">Engineering levers</p>
        <h2>{project.data.toolsTitle}</h2>
      </div>
      <div class="detail-grid">
        {project.data.tools.map((item) => <div class="detail-chip">{item}</div>)}
      </div>
    </section>

    <ArchitectureDiagram
      title={project.data.architectureTitle}
      summary={project.data.architectureSummary}
      layers={project.data.architectureLayers}
    />

    <section class="detail-panel">
      <div class="detail-panel__header">
        <p class="section-kicker">Key decisions</p>
        <h2>Tradeoffs that shaped the final system</h2>
      </div>
      <div class="decision-grid">
        {project.data.decisions.map((item) => (
          <article class="decision-card">
            <h3>{item.title}</h3>
            <p>{item.detail}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="detail-panel">
      <div class="detail-panel__header">
        <p class="section-kicker">Why it mattered</p>
        <h2>Signals that make this case study stand out</h2>
      </div>
      <ul class="detail-list">
        {project.data.special.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="detail-panel prose-block">
      <div class="detail-panel__header">
        <p class="section-kicker">Deep dive</p>
        <h2>Technical narrative</h2>
      </div>
      <Content />
    </section>

    <nav class="project-pagination" aria-label="Project navigation">
      {previous ? <a href={`/projects/${previous.id}/`}>← {previous.data.title}</a> : <span></span>}
      {next ? <a href={`/projects/${next.id}/`}>{next.data.title} →</a> : <span></span>}
    </nav>
  </article>
</MainLayout>
