---
import { getCollection } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import ProjectCard from "../../components/ProjectCard.astro";

const projects = (await getCollection("projects")).sort((a, b) => a.data.order - b.data.order);
const featured = projects.filter((project) => project.data.featured);
const secondary = projects.filter((project) => !project.data.featured);
---

<MainLayout
  title="Projects | Kaizer Charania"
  description="Case studies for Kaizer Charania covering staff-level backend, platform, and distributed-systems work."
  frameClass="site-frame--home"
>
  <section class="project-hub">
    <div class="project-hub__intro">
      <p class="section-kicker">Engineering case studies</p>
      <h1>Technical write-ups focused on system design, tradeoffs, and measurable production impact.</h1>
      <p>
        These are technical case studies on backend, platform, and optimization systems, written to show the architecture,
        tradeoffs, and production outcomes behind the work.
      </p>
    </div>
  </section>

  <section class="project-collection">
    <div class="project-collection__header">
      <p class="section-kicker">Featured studies</p>
      <h2>Flagship technical stories</h2>
    </div>

    <div class="project-grid project-grid--editorial">
      {featured.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <section class="project-collection">
    <div class="project-collection__header">
      <p class="section-kicker">Additional work</p>
      <h2>Adjacent technical exploration</h2>
      <p>Supporting work that broadens the portfolio into adjacent platform and AI-enabled system design patterns.</p>
    </div>

    <div class="project-grid project-grid--secondary">
      {secondary.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <section class="final-cta">
    <p class="section-kicker">Connect</p>
    <h2>If this is the kind of work you are interested in, let’s connect.</h2>
    <div class="hero__actions">
      <a class="button" href="/contact/">Connect</a>
      <a class="button button--ghost" href="/about/">About me</a>
    </div>
  </section>
</MainLayout>
