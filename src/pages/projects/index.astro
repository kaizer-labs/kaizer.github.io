---
import { getCollection } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import SectionBlock from "../../components/SectionBlock.astro";
import ProjectCard from "../../components/ProjectCard.astro";

const projects = (await getCollection("projects")).sort((a, b) => a.data.order - b.data.order);
const featured = projects.filter((project) => project.data.featured);
const secondary = projects.filter((project) => !project.data.featured);
---

<MainLayout
  title="Projects | Kaizer Charania"
  description="Case studies for Kaizer Charania covering staff-level backend, platform, and distributed-systems work."
  frameClass="site-frame--home"
>
  <SectionBlock
    eyebrow="Projects"
    title="Case studies built around scale, judgment, and measurable outcomes."
    description="These projects are the clearest examples of backend and platform work where architecture, performance, delivery, and business impact all show up together."
    className="section-block--wide-title"
  >
    <div class="project-grid">
      {featured.map((project) => <ProjectCard project={project} />)}
    </div>
  </SectionBlock>

  <SectionBlock
    eyebrow="Additional work"
    title="Supporting work that extends the core story."
    description="These projects broaden the portfolio without competing with the flagship backend and platform case studies."
    className="section-block--wide-title"
  >
    <div class="project-grid project-grid--secondary">
      {secondary.map((project) => <ProjectCard project={project} />)}
    </div>
  </SectionBlock>

  <section class="final-cta">
    <p class="section-kicker">Connect</p>
    <h2>If this is the kind of work you are interested in, let’s connect.</h2>
    <div class="hero__actions">
      <a class="button" href="/contact/">Connect</a>
      <a class="button button--ghost" href="/about/">About me</a>
    </div>
  </section>
</MainLayout>
