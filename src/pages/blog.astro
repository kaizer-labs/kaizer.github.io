---
import { getCollection } from "astro:content";
import MainLayout from "../layouts/MainLayout.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
);
const featuredPost = posts.find((post) => post.data.featured) ?? posts[0];
const archivePosts = posts.filter((post) => post.id !== featuredPost.id);
---

<MainLayout
  title="Blog | Kaizer Charania"
  description="Writing on prompt engineering, backend systems, platform work, and technical execution."
  frameClass="site-frame--home"
>
  <section class="blog-hub">
    <div class="blog-hub__intro">
      <p class="section-kicker">Blog</p>
      <h1>Technical writing on how I build systems, lead execution, and use AI thoughtfully in real workflows.</h1>
      <p>
        This section is for longer-form writing: engineering tradeoffs, platform lessons, and the process behind the work shown
        elsewhere on the site.
      </p>
    </div>
  </section>

  {featuredPost && (
    <section class="blog-collection">
      <div class="blog-collection__header">
        <p class="section-kicker">Featured post</p>
        <h2>Start here</h2>
      </div>

      <a class="blog-card blog-card--featured" href={`/blog/${featuredPost.id}/`}>
        <div class="blog-card__meta">
          <span>{featuredPost.data.publishedAt}</span>
          <span>{featuredPost.data.readingTime}</span>
        </div>
        <h3>{featuredPost.data.title}</h3>
        <p>{featuredPost.data.summary}</p>
        <div class="blog-card__tags">
          {featuredPost.data.tags.map((tag) => <span class="tech-tag">{tag}</span>)}
        </div>
      </a>
    </section>
  )}

  {archivePosts.length > 0 && (
    <section class="blog-collection">
      <div class="blog-collection__header">
        <p class="section-kicker">More writing</p>
        <h2>Archive</h2>
      </div>

      <div class="blog-grid">
        {archivePosts.map((post) => (
          <a class="blog-card" href={`/blog/${post.id}/`}>
            <div class="blog-card__meta">
              <span>{post.data.publishedAt}</span>
              <span>{post.data.readingTime}</span>
            </div>
            <h3>{post.data.title}</h3>
            <p>{post.data.summary}</p>
            <div class="blog-card__tags">
              {post.data.tags.map((tag) => <span class="tech-tag">{tag}</span>)}
            </div>
          </a>
        ))}
      </div>
    </section>
  )}
</MainLayout>
