---
import MainLayout from "../layouts/MainLayout.astro";
import SectionBlock from "../components/SectionBlock.astro";
import { writingThemes } from "../data/site";
---

<MainLayout
  title="Notes | Kaizer Charania"
  description="Themes Kaizer Charania may publish on across backend systems, platform engineering, AI retrieval, and engineering execution."
>
  <SectionBlock
    eyebrow="Notes"
    title="Writing directions connected to the work on this site."
    description="This page is intentionally low-profile until real posts are published. The topics below reflect the areas where the hands-on work is strongest."
  >
    <div class="references-list">
      {writingThemes.map((item) => (
        <article class="reference-card">
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
  </SectionBlock>
</MainLayout>
