---
import { getCollection, render } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";

export async function getStaticPaths() {
  const posts = (await getCollection("blog")).sort(
    (a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
  );

  return posts.map((post, index) => ({
    params: { slug: post.id },
    props: {
      post,
      previous: posts[index + 1] ?? null,
      next: posts[index - 1] ?? null
    }
  }));
}

const { post, previous, next } = Astro.props;
const { Content } = await render(post);
---

<MainLayout
  title={`${post.data.title} | Kaizer Charania`}
  description={post.data.summary}
  frameClass="site-frame--home"
>
  <article class="blog-post">
    <a class="back-link" href="/blog/">← Back to blog</a>

    <header class="blog-post__hero">
      <div class="blog-post__meta">
        <span>{post.data.publishedAt}</span>
        <span>{post.data.readingTime}</span>
      </div>
      <p class="section-kicker">Blog post</p>
      <h1>{post.data.title}</h1>
      <p class="blog-post__summary">{post.data.summary}</p>
      <div class="blog-card__tags">
        {post.data.tags.map((tag) => <span class="tech-tag">{tag}</span>)}
      </div>
    </header>

    <section class="detail-panel prose-block blog-post__body">
      <Content />
    </section>

    <nav class="project-pagination" aria-label="Blog navigation">
      {previous ? <a href={`/blog/${previous.id}/`}>← {previous.data.title}</a> : <span></span>}
      {next ? <a href={`/blog/${next.id}/`}>{next.data.title} →</a> : <span></span>}
    </nav>
  </article>
</MainLayout>
