---
import MainLayout from "../layouts/MainLayout.astro";
import SectionBlock from "../components/SectionBlock.astro";
import { leadershipSignals, references } from "../data/site";
---

<MainLayout
  title="Highlights | Kaizer Charania"
  description="Selected outcome and leadership highlights for Kaizer Charania's technical leadership portfolio."
>
  <SectionBlock
    eyebrow="Highlights"
    title="Selected outcome and scope highlights behind the portfolio."
    description="This page is intentionally concrete. It focuses on validated scope, outcomes, people leadership, and execution signals rather than generic testimonials."
  >
    <div class="references-list">
      {references.map((item) => (
        <article class="reference-card">
          <p>{item}</p>
        </article>
      ))}
    </div>
  </SectionBlock>

  <SectionBlock
    eyebrow="Leadership"
    title="Organizational signals behind the technical results."
    description="These are the indicators that the work extends beyond deep individual contribution into broader technical leadership."
  >
    <div class="references-list">
      {leadershipSignals.map((item) => (
        <article class="reference-card">
          <p>{item}</p>
        </article>
      ))}
    </div>
  </SectionBlock>
</MainLayout>
