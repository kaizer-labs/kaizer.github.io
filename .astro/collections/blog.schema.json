{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "publishedAt": {
      "type": "string"
    },
    "readingTime": {
      "type": "string"
    },
    "featured": {
      "default": false,
      "type": "boolean"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "summary",
    "publishedAt",
    "readingTime",
    "featured",
    "tags"
  ],
  "additionalProperties": false
}