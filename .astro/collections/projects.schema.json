{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "subtitle": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "problem": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "scope": {
      "type": "string"
    },
    "year": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "featured": {
      "default": false,
      "type": "boolean"
    },
    "order": {
      "type": "number"
    },
    "tech": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "toolsTitle": {
      "type": "string"
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "special": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "metrics": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "audience": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "architectureTitle": {
      "type": "string"
    },
    "architectureSummary": {
      "type": "string"
    },
    "architectureLayers": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "bullets": {
            "minItems": 1,
            "maxItems": 3,
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "name",
          "description",
          "bullets"
        ],
        "additionalProperties": false
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "detail": {
            "type": "string"
          }
        },
        "required": [
          "title",
          "detail"
        ],
        "additionalProperties": false
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "subtitle",
    "summary",
    "problem",
    "role",
    "scope",
    "year",
    "status",
    "featured",
    "order",
    "tech",
    "toolsTitle",
    "tools",
    "special",
    "metrics",
    "audience",
    "architectureTitle",
    "architectureSummary",
    "architectureLayers",
    "decisions"
  ],
  "additionalProperties": false
}